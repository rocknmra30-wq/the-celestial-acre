<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>The Celestial Acre | Hidden Pocket Hollow</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600&family=Libre+Baskerville&display=swap" rel="stylesheet">

<style>

/* GLOBAL */

body{
margin:0;
font-family:'Libre Baskerville', serif;
color:white;
background:#05040a;
overflow-x:hidden;
}

/* STAR BACKGROUND */

.stars{
position:fixed;
width:100%;
height:100%;
background:
radial-gradient(white 1px, transparent 1px),
radial-gradient(white 1px, transparent 1px);
background-size:50px 50px;
opacity:.15;
z-index:-1;
}

/* HERO */

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;

background:linear-gradient(
rgba(0,0,0,.5),
rgba(0,0,0,.8)
),
url("hero.jpg");

background-size:cover;
background-position:center;
}

.hero h1{
font-family:'Cinzel', serif;
font-size:44px;
letter-spacing:3px;
margin-bottom:10px;
}

.tagline{
font-size:18px;
opacity:.9;
}

/* SECTION */

.section{
max-width:900px;
margin:auto;
padding:60px 25px;
text-align:center;
}

.card{
background:rgba(0,0,0,.55);
border:1px solid rgba(255,255,255,.15);
border-radius:12px;
padding:30px;
backdrop-filter:blur(6px);
}

/* HARVEST */

.harvest-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
gap:20px;
margin-top:20px;
}

.harvest-item{
background:rgba(255,255,255,.06);
padding:18px;
border-radius:10px;
}

/* GALLERY */

.gallery{
margin-top:30px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
gap:12px;
}

.gallery img{
width:100%;
border-radius:10px;
transition:.4s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* ORDER */

input,textarea{
width:100%;
padding:14px;
margin:10px 0;
border-radius:6px;
border:none;
font-size:15px;
}

button{
background:#ffb347;
border:none;
padding:14px 28px;
border-radius:30px;
font-size:16px;
cursor:pointer;
transition:.3s;
}

button:hover{
background:#ff8f1f;
transform:scale(1.05);
}

/* FOOTER */

footer{
padding:30px;
text-align:center;
font-size:14px;
opacity:.7;
}

</style>

</head>


<body>

<div class="stars"></div>

<!-- HERO -->

<section class="hero">

<h1>The Celestial Acre</h1>

<div class="tagline">
Hidden Pocket Hollow • Fresh • Local • Grown With Care
</div>

</section>


<!-- STORY -->

<section class="section">

<div class="card">

<h2>Our Story</h2>

<p>
Hidden Pocket Hollow is a small homestead farm tucked into the hills where
clear skies, quiet fields, and good soil grow honest food.
</p>

<p>
We raise pasture chickens, grow heirloom vegetables,
and share the harvest with our local community.
</p>

</div>

</section>


<!-- HARVEST -->

<section class="section">

<div class="card">

<h2>Our Harvest</h2>

<div class="harvest-grid">

<div class="harvest-item">🥚 Pasture Eggs</div>

<div class="harvest-item">🍅 Heirloom Produce</div>

<div class="harvest-item">🍯 Local Honey</div>

<div class="harvest-item">🥕 Seasonal Vegetables</div>

<div class="harvest-item">🌿 Garden Herbs</div>

<div class="harvest-item">🍓 Strawberries</div>

</div>

</div>

</section>


<!-- GALLERY -->

<section class="section">

<h2>From the Hollow</h2>

<div class="gallery">

<img src="farm1.jpg">
<img src="farm2.jpg">
<img src="farm3.jpg">
<img src="farm4.jpg">
<img src="farm5.jpg">
<img src="farm6.jpg">

</div>

</section>


<!-- ORDER -->

<section class="section">

<div class="card">

<h2>Request a Harvest Box</h2>

<form>

<input placeholder="Name">

<input placeholder="Email or Phone">

<textarea placeholder="What would you like? Eggs, vegetables, honey..."></textarea>

<button>Send Request</button>

</form>

</div>

</section>


<footer>

Hidden Pocket Hollow • Est. 2026  
<br>
The Celestial Acre

</footer>


</body>

</html>
